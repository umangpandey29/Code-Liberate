rules_version = '2';

// Code Liberate Firestore security rules
// Paste this into Firebase Console → Firestore → Rules → Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // /users/{uid} - user can read+write only their own profile
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // /orders/{orderId}
    // - Client can READ only orders where they are the owner
    // - Client can CREATE an order only for themselves
    // - Client can UPDATE only the lastClientReadAt field (and a few of their own fields)
    // - Status, lastTeamMessageAt and team-only fields are write-protected
    //   from clients; only admins (Firebase Console / server) can change them
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
                    && request.resource.data.status == 'Pending'
                    && request.resource.data.userEmail == request.auth.token.email;
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.status == resource.data.status;
      allow delete: if false;

      // /orders/{orderId}/messages/{messageId}
      // - Client can read all messages on their own order
      // - Client can create only a client-type message authored by themselves
      // - Updates and deletes are disallowed (audit trail)
      match /messages/{messageId} {
        allow read: if isOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.userId);
        allow create: if isOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.userId)
                      && request.resource.data.senderType == 'client'
                      && request.resource.data.senderEmail == request.auth.token.email;
        allow update, delete: if false;
      }
    }

    // /leads/{leadId} - marketing-site contact form. Anyone can submit, no one can read.
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Default: deny everything not matched above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
